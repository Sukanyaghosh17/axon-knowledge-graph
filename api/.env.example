# ── Local development ────────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
# Required for production (Vercel). Use MongoDB Atlas free tier:
#   https://cloud.mongodb.com → create cluster → get connection string
# Leave blank locally to use an in-memory MongoDB (for quick testing)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/axon?retryWrites=true&w=majority

# ── CORS ─────────────────────────────────────────────────────
# In production, set this to your Vercel deployment URL, e.g.:
#   CLIENT_URL=https://axon.vercel.app
# Multiple origins can be comma-separated:
#   CLIENT_URL=https://axon.vercel.app,https://www.axon.vercel.app
CLIENT_URL=http://localhost:5173

# ── Node environment ─────────────────────────────────────────
NODE_ENV=development
